# --- Database ---
# Dev: sqlite:///./dev.db   Prod: postgresql+psycopg2://user:pass@host:5432/lumaris
DATABASE_URL=""

# --- JWT signing (HS256). Generate: openssl rand -hex 32 ---
SECRET_KEY=""

# --- Fernet key for API-key encryption ---
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SERVER_PRIVATE_KEY=""

# --- Marketplace economics ---
PLATFORM_TAKE_RATE="0.10"

# --- WireGuard SERVER identity ---
# WG_PUBLIC_KEY is the server's PUBLIC key (safe to expose to clients).
# The server's PRIVATE key must live ONLY on the VPN host's wg config and is
# NEVER read by this API. Do not put a private key here.
WG_PUBLIC_KEY=""
WG_ENDPOINT=""
# Optional: live peer registration (requires `wg` + privileges on the API host)
WG_APPLY="false"
WG_INTERFACE="wg0"

# --- Marketplace / trust ---
MIN_REPUTATION="50"

# --- Admin console (/admin) ---
# Comma-separated usernames or emails granted platform-admin access. Everything
# under /admin/* is gated by this list; leave empty to disable admin entirely.
ADMIN_USERS=""

# --- Payments ---
# sandbox: /deposit mints test credits (dev/demo). live: /deposit disabled,
# balances credited only via the signed payment webhook.
PAYMENTS_MODE="sandbox"
PAYMENT_WEBHOOK_SECRET=""          # HMAC secret for POST /webhooks/payment (Stripe: endpoint secret)

# --- Dashboard ---
AWS_REFERENCE_PRICE="12.29"        # reference $/hr for the savings column

# --- CORS (only needed for a separate frontend/CLI origin; dashboard at / is same-origin) ---
ALLOWED_ORIGINS=""                 # e.g. https://app.petabyte.market

# --- Object storage for backups ---
# The API holds these credentials and mints per-object, time-limited pre-signed
# URLs; seller nodes NEVER receive standing keys. Leave S3_BUCKET empty to disable
# backups. S3_STUB=true short-circuits URL signing for local tests.
S3_BUCKET=""
S3_REGION="us-east-1"
S3_ENDPOINT=""                      # set for Cloudflare R2 / MinIO; empty for AWS
AWS_ACCESS_KEY_ID="__SET_ME__"
AWS_SECRET_ACCESS_KEY="__SET_ME__"
BACKUP_RESCHEDULE_GRACE_S="900"     # refund if a backed-up node never returns

# --- Google sign-in (OAuth) ---
# Create an OAuth 2.0 Client (Web) in Google Cloud Console; add the redirect URI below.
GOOGLE_OAUTH_STUB=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.petabyte.market/auth/google/callback
