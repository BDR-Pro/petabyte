# ================= Petabyte / Lumaris API — environment template =================
# Copy to /etc/lumaris/lumaris.env (deploy.sh generates it for you with real
# secrets). Every variable the app reads is listed. Blanks are OPTIONAL
# integrations, stubbed off until you set them.

# --- Core (REQUIRED; generate real values) ---
DATABASE_URL=postgresql+psycopg2://lumaris:CHANGE_ME@localhost:5432/lumaris
SECRET_KEY=CHANGE_ME_openssl_rand_hex_32
SERVER_PRIVATE_KEY=CHANGE_ME_fernet_key

# --- Web / runtime ---
BIND=127.0.0.1:8000
WEB_CONCURRENCY=2
LOG_LEVEL=info

# --- Monitoring (optional) ---
SENTRY_DSN=

# --- Marketplace economics ---
PLATFORM_TAKE_RATE=0.10
MIN_REPUTATION=50
HEARTBEAT_TIMEOUT_S=60
AWS_REFERENCE_PRICE=12.29
BACKUP_RESCHEDULE_GRACE_S=900

# --- Reaper (keep true: dedicated lumaris-reaper service does the reaping) ---
REAPER_DISABLED=true
REAPER_INTERVAL_S=20

# --- Admin console (/admin) ---
ADMIN_USERS=info@petabyte.market

# --- CORS (only if a separate frontend origin calls the API) ---
ALLOWED_ORIGINS=

# --- Google sign-in (REQUIRED for login) ---
GOOGLE_OAUTH_STUB=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://petabyte.market/auth/google/callback

# --- Payments / deposits ---
PAYMENTS_MODE=sandbox
STRIPE_API_KEY=
PAYMENT_WEBHOOK_SECRET=

# --- Seller payouts (set a provider + PAYOUT_STUB=false to go real) ---
PAYOUT_STUB=true
TREMENDOUS_API=https://api.tremendous.com/api/v2
TREMENDOUS_API_KEY=
TREMENDOUS_FUNDING_ID=
TREMENDOUS_PRODUCT_ID=
CIRCLE_API=https://api.circle.com/v1
CIRCLE_API_KEY=
CIRCLE_WALLET_ID=
USDC_CHAIN=MATIC

# --- Email / notifications ---
NOTIFY_STUB=true
EMAIL_PROVIDER=ses
EMAIL_FROM=no-reply@petabyte.market
SENDGRID_API_KEY=
POSTMARK_TOKEN=

# --- Object storage for backups ---
S3_STUB=true
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- GeoIP data-residency ---
GEOIP_STUB=true
GEOIP_DB=

# --- NiceHash idle-fallback pricing ---
NICEHASH_STUB=true
NICEHASH_API=https://api2.nicehash.com
NICEHASH_API_KEY=
NICEHASH_API_SECRET=
NICEHASH_ORG_ID=

# --- Confidential computing / TEE attestation (optional) ---
TEE_MEASUREMENT_ALLOWLIST=
TEE_TRUSTED_ROOT=

# --- WireGuard (VPN for booked VMs) ---
WG_PUBLIC_KEY=
WG_ENDPOINT=
WG_APPLY=false
WG_INTERFACE=wg0
