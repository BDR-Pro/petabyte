# Petabyte agent configuration
PETABYTE_API_URL=https://petabyte.market
PETABYTE_API_KEY=            # encrypted key from POST /create_api_key on the API
PETABYTE_SPEC_ID=            # the spec id this node serves (from /register_specs)
# Optional tuning
HEARTBEAT_INTERVAL=15
JOB_POLL_INTERVAL=5
SANDBOX_IMAGE=jupyter/base-notebook:latest
NB_TIMEOUT=300
NB_CELL_TIMEOUT=120
