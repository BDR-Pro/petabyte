# Petabyte Desktop Agent configuration.
# You can set these here, or leave blank and enter them in the dashboard UI.
PETABYTE_API_URL=https://petabyte.market
PETABYTE_API_KEY=            # encrypted key from POST /create_api_key (or the /keys page)
PETABYTE_SPEC_ID=            # the spec id this node serves (from /register_specs)
# Optional tuning
HEARTBEAT_INTERVAL=15
JOB_POLL_INTERVAL=5
